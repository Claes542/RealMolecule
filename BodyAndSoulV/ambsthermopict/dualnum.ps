/basefontdict exch def /newfontname exch def
/newfont basefontdict maxlength dict def
basefontdict { exch dup /FID ne {
dup /Encoding eq {exch 256 array copy}{exch} ifelse
newfont 3 1 roll put } { pop pop } ifelse } forall
newfont /FontName newfontname put
newcodesandnames aload pop
newcodesandnames length 2 idiv
{newfont /Encoding get 3 1 roll put}
repeat newfontname newfont definefont end}{exch pop}
ifelse
} bind def
/lf {dup matrix scale exch matrix rotate
     matrix concatmatrix
     exch police exch get findfont
     exch makefont setfont} bind def
/g {setgray} bind def
/c {setrgbcolor} bind def
/C {closepath} bind def
/s {stroke} bind def
/m {moveto} bind def
/l {lineto} bind def
/matrice1 {matini setmatrix ccx cm ccy cm translate
           angle rotate echelle cm dup scale
           hx 2 div neg
           hy 2 div neg translate} def
/matrice {matini setmatrix  
          ccx decxcm add cm
          ccy decycm add cm translate
          angle rotate echelle cm dup scale
          zoomx zoomy scale
          hx 2 div neg hy 2 div neg translate} def
/cadre {currentlinewidth 2 div neg dup
        hx exch sub
        currentlinewidth 2 div neg dup
        hy exch sub rec} def
/showcadre {gsave initclip matrice1 kadre
             {.05 setlinewidth [] 0 setdash
              0. setgray cadre stroke}
            if  grestore} def
/S {moveto lineto stroke} bind def
/d {currentgray mark} bind def
/f {setgray newpath moveto
    counttomark 2 idiv {lineto} repeat
    closepath fill cleartomark setgray} bind def
/inc {matrice1 initclip 0 hx 0 hy rec
      clip newpath matrice} bind def
/hdc {inc rec clip newpath} bind def
/aller {3 copy 3 1 roll moveto currentlinewidth
        exch dup .1 mul setlinewidth} bind def
/seg0 {aller dup neg 0 exch 0 rmoveto rlineto
       stroke setlinewidth} bind def
/seg1 {aller .70711 mul dup dup neg dup rmoveto
       rlineto stroke setlinewidth} bind def
/seg2 {aller dup neg 0 exch 0 4 1 roll rmoveto
       rlineto stroke setlinewidth} bind def
/seg3 {aller .70711 mul neg dup neg dup dup neg
       rmoveto rlineto stroke setlinewidth} bind def
/seg4 {aller 1.414213 mul dup dup neg .5 mul dup rmoveto
      rlineto stroke setlinewidth} bind def
/seg5 {aller 1.414213 mul neg dup neg dup .5 mul dup neg
      rmoveto rlineto stroke setlinewidth} bind def
/seg6 {aller 2 mul dup neg 0 exch .5 mul 0
      rmoveto rlineto stroke setlinewidth} bind def
/seg7 {aller 2 mul dup neg 0 exch .5 mul 0 4 1 roll
      rmoveto rlineto stroke setlinewidth} bind def
/Mc {aller 1.77245 mul neg dup 0 exch 0 exch dup neg
     dup 0 exch 0 exch dup .5 mul neg dup
     rmoveto rlineto rlineto rlineto rlineto
     stroke setlinewidth pop pop pop} bind def
/MC {aller 1.77245 mul neg dup 0 exch 0 exch dup neg
     dup 0 exch 0 exch dup .5 mul neg dup
     rmoveto rlineto rlineto rlineto rlineto
     fill stroke setlinewidth pop pop pop} bind def
/Ml {aller 1.25331 mul neg dup neg dup neg dup dup neg
     dup neg dup neg dup dup neg 0
     rmoveto rlineto rlineto rlineto rlineto
     stroke setlinewidth pop pop pop} bind def
/ML {aller 1.25331 mul neg dup neg dup neg dup dup neg
     dup neg dup neg dup dup neg 0
     rmoveto rlineto rlineto rlineto rlineto
     fill stroke setlinewidth pop pop pop} bind def
/Mt {aller 2.2 mul neg dup neg .5 mul 0 exch dup dup
     1.73205 mul neg exch dup dup 1.73205 mul exch neg dup
     .57735 mul rmoveto rlineto rlineto rlineto
     stroke setlinewidth pop pop pop} bind def
/MT {aller 2.2 mul neg dup neg .5 mul 0 exch dup dup
     1.73205 mul neg exch dup dup 1.73205 mul exch neg dup
     .57735 mul rmoveto rlineto rlineto rlineto
     fill stroke setlinewidth pop pop pop} bind def
/Mt2 {aller 2.2 mul dup neg .5 mul 0 exch dup dup
1.73205 mul neg exch dup dup 1.73205 mul exch neg dup .57735 mul
      rmoveto rlineto rlineto rlineto
      stroke setlinewidth pop pop pop} bind def
/MT2 {aller 2.2 mul dup neg .5 mul 0 exch dup dup
1.73205 mul neg exch dup dup 1.73205 mul exch neg dup
      .57735 mul rmoveto rlineto rlineto rlineto
      fill stroke setlinewidth pop pop pop} bind def
/Mp {seg6 seg7 pop pop pop} bind def
/Mx {seg4 seg5 pop pop pop} bind def
/Ms {3 copy Mp Mx} bind def
/MV {pop pop pop} bind def
/R {currentlinewidth 4 1 roll dup .1 mul
    setlinewidth 0 360 arc stroke
    setlinewidth} bind def
/R2 {0 360 arc stroke} bind def
/Rf {0 360 arc fill} bind def
/E {dup 5 1 roll stringwidth
    2 index neg mul 3 index add exch
    2 index neg mul 4 index add exch
    moveto pop pop pop show newpath} bind def
/cartouche{/dessin dessin 1 add def latex not
          {gsave initgraphics 1 cm 1 cm scale
           grestore} if} def
/typetrait [[]
            [30 70]
            [100]
            [50 70 200 70]
            [150 70]
            [30 30 30 80]
            [30 50 30 50 150 50]
            [250 70]] bind def
/dt {dup 0 lt {pop pop}
      {exch dup 0.1 mul setlinewidth /LW exch def
       8 mod typetrait exch get /tt exch def
[ 0 1 tt length 1 sub {tt exch get LW mul 0.005 mul} for ]
       0 setdash} ifelse} def
/initialise {gsave /initCPU usertime def
    /dessin 1 def /matini matrix currentmatrix def
    latex
    {/echelle
      hhx hx angle cos mul abs
          hy angle sin mul abs add div
      hhy hx angle sin mul abs
          hy angle cos mul abs add div
      2 copy
      gt {exch} if pop
      def
      /xmin 0. def
      /xmax hx def
      /ymin 0. def
      /ymax hy def
      currentpoint
      /ccy exch ptcm div def
      /ccx exch ptcm div def
    }
    {/echelle 1 def
     /xmin 0. def
     /xmax hx def
     /ymin 0. def
     /ymax hy def
     /ccx xpapier 2 div def
     /ccy ypapier 2 div def
    }
    ifelse
    /dessin 0 def
    matrice
    showcadre
    cartouche
    inc
    } def
